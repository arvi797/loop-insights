# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- GitHub (read-only) ---
# A Personal Access Token with READ-ONLY public-repo scope.
# Fine-grained token: "Public Repositories (read-only)" is sufficient.
# Leave blank to run unauthenticated (60 requests/hour — fine for light testing).
GITHUB_TOKEN=

# --- LLM provider for the narrative endpoint ---
# One of: openai | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=
# Default gpt-5.5 (best instruction-following for grounding + calibration).
# Swap to gpt-4.1 for lower latency; structured output is supported on both.
OPENAI_MODEL=gpt-5.5
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Low temperature for faithful, stable narratives. Ignored by reasoning models
# (gpt-5.x / o-series) that pin temperature to their default.
LLM_TEMPERATURE=0.2

# --- App ---
# Default repo to analyze when none is specified (owner/name).
DEFAULT_REPO=fastapi/fastapi
# SQLite path for the local cache/store.
DATABASE_URL=sqlite:///./data/loop.db
# Per-request upstream page cap (safety bound on how much we pull).
MAX_PAGES=10
LOG_LEVEL=INFO
